難平.\n\n[Verse: Main Theme: 30s]\n\n[Vocal: Same melody as previous theme, Confident, Melodic]\n\n[Instrumental: Maximum energy, Anthemic arrangement, High-fidelity]\n一盞 舊燈火, 映著 妳 輪廓,\n這場 故鄉夢, 我 捨不得 破.\n看 幾番 秋色, 聽 幾聲 離合,\n唯有 妳的美, 依然 深刻.\n一盞 舊燈火\n\n映著 妳 輪廓,\n這場 故鄉夢, 我 捨不得 破.\n那 漫天 星斗, 像 妳的 溫柔,\n(whispered, gently, stable)\n等我 這一回, 攜手 白頭.\n(vocal stop, staccato)\n\n[Outro: 5s]\n[Vocal: None, Pure Instrumental]\n[Instrumental: Pipa mimicking main melody hook, Gentle fade out, Fading]\n[End]",31,"fixed",108,192,"4","zh","A major",true,2,0.48,0.9,0,0]},{"id":107,"type":"SaveAudioMP3","pos":[1886.039438366296,-753.7929465207981],"size":[1096.5333251953125,186.53334045410156],"flags":{},"order":12,"mode":0,"inputs":[{"label":"audio","localized_name":"音频","name":"audio","type":"AUDIO","link":263},{"label":"filename_prefix","localized_name":"文件名前缀","name":"filename_prefix","type":"STRING","widget":{"name":"filename_prefix"},"link":null},{"label":"quality","localized_name":"质量","name":"quality","type":"COMBO","widget":{"name":"quality"},"link":null},{"label":"audioUI","localized_name":"audioUI","name":"audioUI","type":"AUDIO_UI","widget":{"name":"audioUI"},"link":null}],"outputs":[],"properties":{"cnr_id":"comfy-core","ver":"0.11.1","Node name for S&R":"SaveAudioMP3","enableTabs":false,"tabWidth":65,"tabXOffset":10,"hasSecondTab":false,"secondTabText":"Send Back","secondTabOffset":80,"secondTabWidth":65},"widgets_values":["audio/ComfyUI","V0"]}],"links":[[119,47,0,3,2,"CONDITIONING"],[175,78,0,3,0,"MODEL"],[249,98,0,3,3,"LATENT"],[250,99,0,98,0,"FLOAT"],[251,99,0,94,5,"FLOAT"],[254,94,0,3,1,"CONDITIONING"],[255,94,0,47,0,"CONDITIONING"],[256,3,0,18,0,"LATENT"],[257,102,0,94,3,"INT"],[258,102,0,3,4,"INT"],[260,104,0,78,0,"MODEL"],[261,105,0,94,0,"CLIP"],[262,106,0,18,1,"VAE"],[263,18,0,107,0,"AUDIO"]],"groups":[{"id":1,"title":"Step 1 - Load Models","bounding":[-214,-1030,486,553.92],"color":"#3f789e","font_size":24,"flags":{}},{"id":2,"title":"Step 2 - Duration","bounding":[-2