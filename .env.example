# ComfyUI 工作流管理器配置
# 复制此文件到 .env 文件并填写您的 ComfyUI 路径

# ComfyUI 安装路径，程序将根据该路径找到所有模型、工作流等文件
COMFYUI_BASE_DIR=REPLACE_WITH_YOUR_COMFYUI_PATH

# 本地工作流备份目录（相对路径），默认值为 workflow
# API 工具将使用该目录下的工作流文件进行调用
LOCAL_WORKFLOWS_DIR=workflow

# 工作流、模型子目录（可选 - 如果未指定则从 base_dir 计算）
# COMFYUI_WORKFLOWS_DIR=C:/Users/YourName/ComfyUI/user/default/workflows
# COMFYUI_MODELS_DIR=C:/Users/YourName/ComfyUI/models
